{
  "name": "terremoto-venezuela",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview": "pnpm build:cloudflare && wrangler dev",
    "deploy": "pnpm build:cloudflare && opennextjs-cloudflare deploy --env production",
    "deploy:preview": "pnpm build:cloudflare && opennextjs-cloudflare deploy --env preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:pull:production": "bash scripts/pull-prod-db.sh",
    "db:migrate:local": "wrangler d1 migrations apply terremoto-reports-local --local",
    "db:migrate:preview": "wrangler d1 migrations apply terremoto-reports-preview --remote --env preview",
    "db:migrate:production": "wrangler d1 migrations apply terremoto-reports --remote --env production",
    "discover:sar": "tsx scripts/discover-sar-scenes.ts",
    "import:source": "tsx scripts/import-terremoto-source.ts",
    "import:satellite": "tsx scripts/import-satellite.ts",
    "import:satellite:ems": "tsx scripts/import-satellite.ts --tier ems",
    "import:satellite:ems-local": "tsx scripts/import-satellite.ts --tier ems-local",
    "import:satellite:ems-zones": "tsx scripts/import-satellite.ts --tier ems-zones",
    "import:satellite:zones-local": "tsx scripts/import-satellite.ts --tier zones-local",
    "import:satellite:candidates": "tsx scripts/import-satellite.ts --tier candidates",
    "import:satellite:maxar": "tsx scripts/import-satellite.ts --tier maxar",
    "import:satellite:sar": "tsx scripts/import-satellite.ts --tier sar",
    "import:satellite:usgs": "tsx scripts/import-satellite.ts --tier usgs",
    "import:satellite:gdacs": "tsx scripts/import-satellite.ts --tier gdacs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@jsquash/webp": "^1.5.0",
    "@opennextjs/cloudflare": "^1.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.13.7",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-country-state-city": "^1.1.13",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-phone-number-input": "^3.4.17",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260625.1",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "geotiff": "^2.1.3",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
